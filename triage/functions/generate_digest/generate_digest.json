{
  "name": "generate_digest",
  "description": "Queries signals and clusters, generates a structured markdown product intelligence report, and writes it to the reports table",
  "code": { "$file": "code.py" },
  "visibility": "POD",
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "signals",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "clusters",
        "permission_ids": ["datastore.table.read", "datastore.record.read"]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "reports",
        "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"]
      }
    ]
  }
}
